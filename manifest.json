{
  "manifest_version": 3,
  "name": "Tab Relocation",
  "version": "1.0",
  "permissions": ["menus", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-teleport@jebsmartt.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}